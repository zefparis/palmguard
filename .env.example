# PalmGuard API — environment variables (Phase 4)
# Copy to .env and fill in values. NEVER commit .env to git.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4010
NODE_ENV=production

# ─── HCS-U7 Auth (Phase 4) ────────────────────────────────────────────────────
# HMAC-SHA256 secret for HS256 JWT verification (issued by hcs-u7-backend).
# Also used to derive per-user vault KEKs (HKDF-SHA-256).
# Minimum 32 random bytes, hex-encoded. NEVER log or expose this value.
HCS_TOKEN_SECRET=

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Use service_role key (server-side only). Bypasses RLS — keep secret.

# ─── Rate Limiter ─────────────────────────────────────────────────────────────
# 'memory' = single-instance (Fly.io / Render single node)
# 'supabase' = multi-instance (requires palm_rate_limits table from migration 003)
RATE_LIMITER_MODE=supabase

# ─── Celestial Entropy ────────────────────────────────────────────────────────
# Replay window in ms (default 60000 = 1 minute)
CELESTIAL_REPLAY_WINDOW_MS=60000

# ─── Security ─────────────────────────────────────────────────────────────────
# Minimum server-side processing time for all responses (timing oracle prevention)
MIN_VERIFY_LATENCY_MS=150
